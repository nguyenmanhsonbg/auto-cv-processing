# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/interview_assistant
TYPEORM_SYNCHRONIZE=false

# JWT
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# App
NODE_ENV=development
PORT=3000

# File uploads
UPLOAD_DIR=./uploads
# Must not be inside UPLOAD_DIR; original CVs in quarantine are not public/downloadable.
CV_QUARANTINE_DIR=./storage/cv-quarantine
# Must not be inside UPLOAD_DIR or CV_QUARANTINE_DIR; clean CVs are served only by controlled APIs.
CV_SAFE_DIR=./storage/cv-safe
# Stub scanner modes: PASSED, REJECTED_MALWARE, FAILED.
CV_SCANNER_STUB_RESULT=PASSED
CV_SCANNER_TIMEOUT_MS=15000
# PDF sanitizer modes: GHOSTSCRIPT_DOCKER. Non-PDF sanitizers are intentionally not enabled in Phase 1 yet.
CV_PDF_SANITIZER_MODE=GHOSTSCRIPT_DOCKER
# Set to a vetted Ghostscript image available in your registry before enabling real PDF sanitization.
CV_GHOSTSCRIPT_DOCKER_IMAGE=
CV_GHOSTSCRIPT_TIMEOUT_MS=60000

# Registration
OPEN_REGISTRATION=true
# Set to false to require an invite token for all registrations

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3002/api/auth/google/callback
FRONTEND_URL=http://localhost:3001
EXTENSION_ALLOWED_ORIGINS=
# Comma-separated emails that are auto-created as ADMIN on first Google login
ADMIN_EMAILS=

# Claude AI (for profile parsing, question suggestion, evaluation summary)
ANTHROPIC_API_KEY=your-api-key

# Telegram Bot (for interview notifications)
TELEGRAM_BOT_TOKEN=
# Comma-separated list of Telegram chat IDs for admin notifications
TELEGRAM_ADMIN_CHAT_IDS=

# Facebook publishing
# Leave empty to use embedded Playwright RPA in the backend.
# Set to http://127.0.0.1:18990 only when running a separate internal RPA worker.
FACEBOOK_RPA_BASE_URL=
FACEBOOK_RPA_SESSION_PATH=./storage/facebook-rpa/storage-state.json
FACEBOOK_RPA_USER_DATA_DIR=./storage/facebook-rpa/user-data
FACEBOOK_RPA_ARTIFACTS_DIR=./storage/facebook-rpa/artifacts
FACEBOOK_RPA_BROWSER_CHANNEL=
FACEBOOK_RPA_HEADLESS=false
FACEBOOK_RPA_TIMEOUT_MS=120000
FACEBOOK_RPA_NAVIGATION_TIMEOUT_MS=60000
FACEBOOK_LOGIN_WAIT_TIMEOUT_MS=600000
FACEBOOK_LOGIN_WAIT_INTERVAL_MS=2000
FACEBOOK_RPA_AFTER_SUBMIT_WAIT_MS=10000
FACEBOOK_RPA_DELAY_MIN_MS=1500
FACEBOOK_RPA_DELAY_MAX_MS=4500
FACEBOOK_RPA_AFTER_NAVIGATION_DELAY_MIN_MS=2500
FACEBOOK_RPA_AFTER_NAVIGATION_DELAY_MAX_MS=6000
FACEBOOK_RPA_AFTER_OPEN_COMPOSER_DELAY_MIN_MS=2000
FACEBOOK_RPA_AFTER_OPEN_COMPOSER_DELAY_MAX_MS=5000
FACEBOOK_RPA_BEFORE_FILL_DELAY_MIN_MS=1500
FACEBOOK_RPA_BEFORE_FILL_DELAY_MAX_MS=3500
FACEBOOK_RPA_AFTER_FILL_DELAY_MIN_MS=2500
FACEBOOK_RPA_AFTER_FILL_DELAY_MAX_MS=6000
FACEBOOK_RPA_AFTER_SUBMIT_SETTLE_DELAY_MIN_MS=4000
FACEBOOK_RPA_AFTER_SUBMIT_SETTLE_DELAY_MAX_MS=9000
FACEBOOK_PUBLISH_TARGET_DELAY_MIN_MS=45000
FACEBOOK_PUBLISH_TARGET_DELAY_MAX_MS=90000
FACEBOOK_RPA_RETRY_COUNT=3
FACEBOOK_RPA_SLOW_MO_MS=80
# Optional JSON arrays or semicolon-separated name|url|externalId entries.
FACEBOOK_GROUP_TARGETS=
FACEBOOK_FANPAGE_TARGETS=
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_GRAPH_API_VERSION=v20.0
FACEBOOK_DEFAULT_FANPAGE_NAME=VCS Careers
FACEBOOK_CANDIDATE_CTA_URL_BASE=/jobs
