# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/interview_assistant
TYPEORM_SYNCHRONIZE=false

# JWT
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# App
NODE_ENV=development
PORT=3000

# File uploads
UPLOAD_DIR=./uploads
# Must not be inside UPLOAD_DIR; original CVs in quarantine are not public/downloadable.
CV_QUARANTINE_DIR=../../storage/cv-quarantine
# Must not be inside UPLOAD_DIR or CV_QUARANTINE_DIR; clean CVs are served only by controlled APIs.
CV_SAFE_DIR=../../storage/cv-safe
# Malware scanning is skipped; CVs still go through sanitization before parsing.
# PDF sanitizer modes: DISPOSABLE_POOL, GHOSTSCRIPT_DOCKER, HTTP_SERVICE.
CV_PDF_SANITIZER_MODE=DISPOSABLE_POOL
CV_SANITIZER_SERVICE_URL=http://localhost:8080
# Only used when CV_PDF_SANITIZER_MODE=GHOSTSCRIPT_DOCKER.
CV_GHOSTSCRIPT_DOCKER_IMAGE=
CV_GHOSTSCRIPT_TIMEOUT_MS=60000
# Only used when CV_PDF_SANITIZER_MODE=DISPOSABLE_POOL.
CV_SANITIZER_POOL_ENABLED=true
CV_SANITIZER_POOL_MANAGER=false
CV_SANITIZER_POOL_MIN_READY=1
CV_SANITIZER_POOL_MAX_WORKERS=2
CV_SANITIZER_JOB_TIMEOUT_MS=60000
CV_SANITIZER_MAX_ATTEMPTS=2
CV_SANITIZER_READY_TIMEOUT_MS=30000
CV_SANITIZER_RECONCILE_INTERVAL_MS=1000
CV_SANITIZER_JOB_WAIT_TIMEOUT_MS=90000
CV_SANITIZER_WORKER_IMAGE=auto-cv-processing-cv-sanitizer-worker:latest
CV_SANITIZER_CONTROL_DIR=../../storage/cv-sanitizer-control

# Registration
OPEN_REGISTRATION=true
# Set to false to require an invite token for all registrations

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3002/api/auth/google/callback
FRONTEND_URL=http://localhost:3001
EXTENSION_ALLOWED_ORIGINS=
# Comma-separated emails that are auto-created as ADMIN on first Google login
ADMIN_EMAILS=

# Claude AI (for profile parsing, question suggestion, evaluation summary)
ANTHROPIC_API_KEY=your-api-key

# Gemini AI (for sanitized CV parsed profile enrichment)
GEMINI_API_KEY=
# Rotation order for sanitized CV parsing. Override if a model id is unavailable in your account/region.
GEMINI_CV_PARSE_MODELS=gemini-2.5-flash,gemini-2.5-flash-lite,gemini-3-flash,gemini-3.1-flash-lite
GEMINI_CV_PARSE_TIMEOUT_MS=45000
GEMINI_CV_PARSE_MAX_CHARS=36000

# Telegram Bot (for interview notifications)
TELEGRAM_BOT_TOKEN=
# Comma-separated list of Telegram chat IDs for admin notifications
TELEGRAM_ADMIN_CHAT_IDS=

# Mail Configuration (SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM=

# Facebook extension publishing
GEMINI_API_KEY=
FACEBOOK_DEFAULT_FANPAGE_NAME=VCS Careers
FACEBOOK_CANDIDATE_CTA_URL_BASE=/jobs
FACEBOOK_PUBLISH_TARGET_DELAY_MIN_MS=45000
FACEBOOK_PUBLISH_TARGET_DELAY_MAX_MS=90000

# VCS Portal JD sync
VCS_PORTAL_BASE_URL=
VCS_PORTAL_API_KEY=
VCS_PORTAL_SYNC_TIMEOUT_MS=30000
VCS_PORTAL_MAX_PAGES=100
