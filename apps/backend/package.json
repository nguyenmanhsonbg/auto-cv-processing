{
  "name": "@interview-assistant/backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "pnpm --filter @interview-assistant/shared build; if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }; nest build; if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }; tsc -p tsconfig.migrate.json",
    "dev": "node scripts/dev.mjs",
    "start": "nest start",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "typecheck": "pnpm --filter @interview-assistant/shared build && tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "migration:generate": "typeorm migration:generate -d dist/config/typeorm.config.js",
    "migration:run": "typeorm migration:run -d dist/config/typeorm.config.js",
    "migration:revert": "typeorm migration:revert -d dist/config/typeorm.config.js"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.92",
    "@anthropic-ai/sdk": "^0.82.0",
    "@interview-assistant/shared": "workspace:*",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/platform-socket.io": "^10.4.15",
    "@nestjs/swagger": "^8.1.0",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^10.0.2",
    "@nestjs/websockets": "^10.4.15",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^17.3.1",
    "exceljs": "^4.4.0",
    "express-session": "^1.19.0",
    "helmet": "^8.1.0",
    "jszip": "^3.10.1",
    "mammoth": "^1.8.0",
    "multer": "^1.4.5-lts.1",
    "nanoid": "^3.3.7",
    "node-cron": "^4.2.1",
    "node-telegram-bot-api": "^0.67.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pdf-parse": "^1.1.1",
    "pg": "^8.13.1",
    "playwright": "^1.61.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "slugify": "^1.6.9",
    "socket.io": "^4.8.1",
    "typeorm": "^0.3.20",
    "uuid": "^13.0.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.0",
    "@types/express-session": "^1.18.2",
    "@types/helmet": "^4.0.0",
    "@types/jszip": "^3.4.1",
    "@types/multer": "^1.4.12",
    "@types/node-cron": "^3.0.11",
    "@types/node-telegram-bot-api": "^0.64.14",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/pdf-parse": "^1.1.4",
    "@types/uuid": "^11.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  }
}
